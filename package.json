{
  "name": "coffeeclaw",
  "version": "1.0.0",
  "description": "OpenClaw Chat Desktop App - AI Assistant powered by Zhipu GLM",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "compile": "coffee -c -b --transpile src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "payment-server": "coffee -c src/payment-server.coffee && node src/payment-server.js",
    "build": "npm run compile && electron-builder",
    "build:mac": "npm run compile && electron-builder --mac",
    "build:win": "npm run compile && electron-builder --win",
    "build:linux": "npm run compile && electron-builder --linux",
    "build:all": "npm run compile && electron-builder --mac --win --linux"
  },
  "author": "CoffeeClaw Team",
  "homepage": "https://github.com/yourusername/coffeeclaw",
  "license": "MIT",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "chai": "^6.2.2",
    "coffeescript": "^2.7.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "mocha": "^11.7.5",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "electron-store": "^10.1.0",
    "express": "^4.18.2",
    "stripe": "^14.0.0",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.coffeeclaw.app",
    "productName": "CoffeeClaw",
    "copyright": "Copyright © 2025 CoffeeClaw Team",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.coffee",
      "!.secret/**",
      "!screen.png",
      "!dist/**",
      "!node_modules/.cache/**",
      "!AI.md",
      "!glm5.md"
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.productivity",
      "identity": null
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "maintainer": "CoffeeClaw Team <coffeeclaw@example.com>"
    }
  }
}
