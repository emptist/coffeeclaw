{
  "name": "coffeeclaw",
  "version": "1.0.0",
  "description": "OpenClaw Chat Desktop App - AI Assistant powered by Zhipu GLM",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "compile": "coffee -c src/",
    "build": "npm run compile && electron-builder",
    "build:mac": "npm run compile && electron-builder --mac",
    "build:win": "npm run compile && electron-builder --win",
    "build:linux": "npm run compile && electron-builder --linux",
    "build:all": "npm run compile && electron-builder --mac --win --linux"
  },
  "author": "CoffeeClaw Team",
  "license": "MIT",
  "devDependencies": {
    "coffeescript": "^2.7.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.coffeeclaw.app",
    "productName": "CoffeeClaw",
    "copyright": "Copyright © 2025 CoffeeClaw Team",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!**/*.coffee",
      "!.secrete/**",
      "!screen.png",
      "!dist/**",
      "!node_modules/.cache/**"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility"
    }
  }
}
